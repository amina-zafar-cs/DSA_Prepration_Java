Problem: printx^n

Solution:

import java.util.*;
public class Power{

	public static void main(String args[]){
	
		System.out.print(power(2,10));
		
	}

	public static int power(int a, int n){

		if(n==0){

			return 1;

		}
		int half=power(a,n/2);

		half=half*half;

		if(n%2==0){
			return half;

		}
		else{

			return a*half;

		}


	}
		
	

}
















Problem: Find factorial of n.

Solution:

import java.util.*;
public class FActorial{

	public static void main(String args[]){
	
		
		System.out.print(factorial(0));
		
	}

	public static int factorial(int n){


		if(n==0){
			return 1;
		}

		int fact=n*factorial(n-1);

		return fact;		


	}
		
	

}
















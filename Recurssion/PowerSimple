Problem: Print x^n

Solution:Simple 

import java.util.*;
public class Power_simple{

	public static void main(String args[]){
	
		//int arr[]={10,2,8,7,7,7,9,7};
		System.out.print(power(2,10));
		
	}

	public static int power(int a, int n){

		if(n==0){

			return 1;

		}
		
		
		return a*power(a,n-1);

	}
		
}


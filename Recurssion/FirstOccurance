Problem: Find the first occurance of an element in array.

Solution: 

import java.util.*;
public class FirstOccurance{

	public static void main(String args[]){
	
		int arr[]={10,2,3,4,7,9};
		System.out.print(firstOccurance(arr,0,4));	
	}

	public static int firstOccurance(int n[],int i,int target){

		if(i==(n.length)){
			return -1;
			
		}

		else if(n[i]==target){
		
			
			return i;

		}

		else{

			return firstOccurance(n,(i+1),target);

		}

	}
}
















Problem:
Print numbers from n to 1 in decreasing order

Solution: 

import java.util.*;
public class Recursion{

	public static void main(String args[]){
			
		print(5);
			
	}

	public static void print(int n){


		if(n==1){

			System.out.print("1");
			
			return;

		}
		System.out.print(n+" ");

		print(n-1);

	}

}















